{
  "name": "@sanity/agent-context",
  "version": "0.6.0",
  "description": "Tools for building AI agents with structured access to Sanity content",
  "keywords": [
    "sanity",
    "ai",
    "agent",
    "mcp",
    "studio"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/agent-context.git",
    "directory": "packages/agent-context"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./studio": {
      "source": "./src/studio/index.ts",
      "import": "./dist/studio.js",
      "default": "./dist/studio.js"
    },
    "./insights": {
      "source": "./src/insights/index.ts",
      "import": "./dist/insights.js",
      "default": "./dist/insights.js"
    },
    "./ai-sdk": {
      "source": "./src/integrations/ai-sdk/index.ts",
      "import": "./dist/ai-sdk.js",
      "default": "./dist/ai-sdk.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pkg build --strict --clean --check",
    "check:lint": "eslint .",
    "check:lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit",
    "dev": "pkg-utils watch",
    "test": "vitest run --typecheck",
    "test:unit": "vitest --typecheck",
    "test:unit:coverage": "vitest run --coverage"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "groq-js": "^1.29.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@sanity/color": "catalog:",
    "@sanity/icons": "catalog:",
    "@sanity/pkg-utils": "^10.4.13",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/ui": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "^4.0.18",
    "ai": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-rx": "^4.2.2",
    "rxjs": "^7.8.2",
    "sanity": "catalog:",
    "styled-components": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@sanity/client": "^7",
    "@sanity/color": "^3",
    "@sanity/icons": "^3",
    "@sanity/ui": "^3",
    "ai": "^6.0.175",
    "react": "^19",
    "react-dom": "^19",
    "react-rx": "^4",
    "rxjs": "^7",
    "sanity": "^5",
    "styled-components": "^6",
    "zod": "^3.20 || ^4"
  },
  "peerDependenciesMeta": {
    "@sanity/client": {
      "optional": true
    },
    "@sanity/color": {
      "optional": true
    },
    "@sanity/icons": {
      "optional": true
    },
    "@sanity/ui": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-rx": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "sanity": {
      "optional": true
    },
    "styled-components": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
