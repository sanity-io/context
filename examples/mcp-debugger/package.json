{
  "name": "@sanity/mcp-debugger",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal chat UI for debugging a Sanity Context MCP: see the agent's tool calls and conversation history",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "check:types": "tsc --noEmit",
    "dev": "concurrently -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/mcp": "^1.0.41",
    "@ai-sdk/react": "^3.0.179",
    "ai": "^6.0.177",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
