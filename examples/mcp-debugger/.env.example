# MCP Debugger configuration
# Copy this file to .env and fill in your values

# The context MCP server to debug (HTTP transport).
# e.g. the Sanity Context MCP URL from the Agent Context plugin, or a local dev server.
MCP_URL=http://127.0.0.1:4111

# Bearer token for the MCP server, if it requires auth. Leave blank if not needed.
MCP_TOKEN=

# MCP transport: "http" (Streamable HTTP) or "sse". Default: http.
# If you get "This server does not support HTTP transport. Try using `sse`",
# set this to sse (and make sure MCP_URL points at the SSE endpoint, often /sse).
MCP_TRANSPORT=http

# Anthropic API key for the agent.
ANTHROPIC_API_KEY=

# Model to use (optional, defaults to claude-sonnet-4-5).
# ANTHROPIC_MODEL=claude-sonnet-4-5

# System prompt for the debugging agent. Keep it minimal so you observe the
# MCP tools' natural behavior. Override to mirror your production agent's prompt.
SYSTEM_PROMPT=You are a helpful assistant with access to tools from a Sanity Context MCP server. Use the tools to answer questions. When you query, prefer being explicit about what you are querying and why.

# Port for the local agent server (the Vite frontend proxies /api to it).
PORT=58400
